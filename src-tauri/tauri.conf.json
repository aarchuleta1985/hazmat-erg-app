{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hazmat ERG Field Reference",
  "version": "1.0.0",
  "identifier": "com.hazmaterg.fieldreference",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hazmat + ERG 2024 Field Reference",
        "width": 1200,
        "height": 820,
        "minWidth": 480,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Change Me LLC",
    "copyright": "Reference tool only. Content sourced from 49 CFR Title 49 Parts 100-177 and U.S. DOT/PHMSA ERG2024. Always verify against current official editions.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
